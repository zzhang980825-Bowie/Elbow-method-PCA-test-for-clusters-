import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler

# Load the two datasets
data1 = pd.read_csv
data2 = pd.read_csv

data1_numeric = data1.select_dtypes(include=['number'])
data2_numeric = data2.select_dtypes(include=['number'])

# Fill NaN values with 0
data1_numeric = data1_numeric.fillna(0)
data2_numeric = data2_numeric.fillna(0)

# Standardize the data
scaler = StandardScaler()
data1_scaled = scaler.fit_transform(data1_numeric)
data2_scaled = scaler.fit_transform(data2_numeric)

# Perform PCA to reduce dimensionality
pca = PCA(n_components=2)
data1_pca = pca.fit_transform(data1_scaled)
data2_pca = pca.fit_transform(data2_scaled)

# Perform clustering
kmeans = KMeans(n_clusters=2, random_state=0)
cluster_labels_data1 = kmeans.fit_predict(data1_scaled)
cluster_labels_data2 = kmeans.fit_predict(data2_scaled)

# Assign cluster labels back to the original datasets
data1['Cluster'] = cluster_labels_data1
data2['Cluster'] = cluster_labels_data2

# Plot the clustering results for data1
plt.figure(figsize=(12, 6))
plt.subplot(1, 2, 1)
plt.scatter(data1_pca[:, 0], data1_pca[:, 1], c=cluster_labels_data1, cmap='viridis')
plt.title('Clustering Results for Bid revised')
plt.xlabel('Principal Component 1')
plt.ylabel('Principal Component 2')
plt.colorbar()

# Plot the clustering results for data2
plt.subplot(1, 2, 2)
plt.scatter(data2_pca[:, 0], data2_pca[:, 1], c=cluster_labels_data2, cmap='viridis')
plt.title('Clustering Results for Bid Original Data')
plt.xlabel('Principal Component 1')
plt.ylabel('Principal Component 2')
plt.colorbar()

plt.tight_layout()
plt.show()


